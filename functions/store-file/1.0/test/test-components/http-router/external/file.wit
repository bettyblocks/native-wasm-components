package betty-blocks:file;

interface store {
    use betty-blocks:data-api/data-api.{helper-context};
    use betty-blocks:types/types.{model, property};

    type download-headers = option<list<tuple<string, string>>>;

    record store-file-result {
        reference: string,
        file-size: u64,
        message: option<string>,
    }

    record url-source {
        url: string,
        headers: download-headers,
    }

    record base64-source {
        data: string,
        filename: string,
    }

    record source-content {
        url-source: option<url-source>,
        base64-source: option<base64-source>,
    }

    store-file: func(helper-context: helper-context, model: model, property: property, source: source-content) -> result<store-file-result, string>;
}
