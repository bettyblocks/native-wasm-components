package betty-blocks:file;

interface upload-file {
    use betty-blocks:types/types.{model, property};

    record upload-result {
        reference: string,
        file-size: u64,
        message: option<string>,
    }

    upload: func(
        model: model,
        property: property,
        file-bytes: list<u8>,
        filename: string,
        content-type: string,
    ) -> result<upload-result, string>;
}

interface store {
    use betty-blocks:data-api/data-api.{helper-context};
    use betty-blocks:types/types.{model, property};

    type download-headers = option<list<tuple<string, string>>>;

    record store-file-result {
        reference: string,
        file-size: u64,
        message: option<string>,
    }

    record url-source {
        url: string,
        headers: download-headers,
    }

    record base64-source {
        data: string,
        filename: string,
    }

    variant file-source {
        url(url-source),
        base64(base64-source),
    }

    store-file: func(helper-context: helper-context, model: model, property: property, source: file-source) -> result<store-file-result, string>;
}
